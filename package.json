{
  "name": "@mappedinfo/llm-architecture-svg",
  "version": "0.1.0",
  "description": "Generate standalone SVG diagrams for GPT/LLM architectures without model weights.",
  "keywords": [
    "llm",
    "gpt",
    "transformer",
    "architecture",
    "svg",
    "visualization"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Mappedinfo/llm-architecture-svg#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mappedinfo/llm-architecture-svg.git"
  },
  "bugs": {
    "url": "https://github.com/Mappedinfo/llm-architecture-svg/issues"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "llm-architecture-svg": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "examples"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "export": "tsx src/cli.ts",
    "demo:basic": "tsx examples/api-basic.ts",
    "demo:expanded": "tsx examples/api-expanded.ts",
    "demo:custom": "tsx examples/api-custom-spec.ts",
    "demo:profiles": "tsx examples/api-profiles.ts",
    "demo:figures": "tsx examples/figure-lsa.ts && tsx examples/figure-ngram.ts",
    "demo:gallery": "tsx examples/gallery.ts",
    "demo:batch": "tsx src/cli.ts --batch examples/llm-svg-batch.json --out artifacts/demo/batch",
    "site:dev": "vite --config site/vite.config.ts",
    "site:build": "vite build --config site/vite.config.ts",
    "site:preview": "vite preview --config site/vite.config.ts",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.22.4",
    "typescript": "^5.2.2",
    "vite": "^6.4.3"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}

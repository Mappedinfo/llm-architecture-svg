{
  "name": "@mappedinfo/llm-architecture-svg",
  "version": "0.1.0",
  "description": "Generate standalone SVG diagrams for GPT/LLM architectures without model weights.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "llm-architecture-svg": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "export": "tsx src/cli.ts",
    "demo:basic": "tsx examples/api-basic.ts",
    "demo:expanded": "tsx examples/api-expanded.ts",
    "demo:custom": "tsx examples/api-custom-spec.ts",
    "demo:batch": "tsx src/cli.ts --batch examples/llm-svg-batch.json --out artifacts/demo/batch",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.2.2"
  }
}
